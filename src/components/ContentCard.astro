---
import DifficultyBadge from './DifficultyBadge.astro';
import { slugifyTag, localePath } from '../utils/i18n';
import type { Locale } from '../utils/i18n';

interface Props {
  title: string;
  description: string;
  href: string;
  difficulty: 'beginner' | 'intermediate' | 'advanced';
  category: string;
  tags: string[];
  locale: Locale;
  readingTime?: number;
  acronym?: string;
}

const { title, description, href, difficulty, category, tags, locale, readingTime, acronym } =
  Astro.props;
---

<article class="group flex flex-col bg-white border border-gray-200 rounded-xl p-6 hover:border-indigo-300 hover:shadow-md transition-all duration-200">
  <div class="flex items-start justify-between gap-3 mb-3">
    <div class="flex flex-wrap items-center gap-2">
      <DifficultyBadge difficulty={difficulty} locale={locale} />
      <span class="text-xs text-gray-500 capitalize">{category}</span>
    </div>
    {readingTime && (
      <span class="text-xs text-gray-500 shrink-0">{readingTime} min</span>
    )}
  </div>

  <h2 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-indigo-600 transition-colors leading-snug">
    <a href={href} class="no-underline after:absolute after:inset-0">
      {acronym ? `${acronym} — ${title.replace(/^[^—]+—\s*/, '')}` : title}
    </a>
  </h2>

  <p class="text-sm text-gray-600 leading-relaxed flex-1 line-clamp-3">{description}</p>

  {tags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-1.5">
      {tags.slice(0, 3).map((tag) => (
        <a
          href={localePath(locale, `tags/${slugifyTag(tag)}`)}
          class="text-xs text-gray-500 bg-gray-50 border border-gray-200 rounded px-2 py-0.5 hover:text-indigo-600 hover:border-indigo-300 transition-colors no-underline"
          onclick="event.stopPropagation()"
        >
          {tag}
        </a>
      ))}
    </div>
  )}
</article>
