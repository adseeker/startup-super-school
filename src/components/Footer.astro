---
import { getTranslations, localePath } from '../utils/i18n';
import type { Locale } from '../utils/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
const year = new Date().getFullYear();
const copyright = t.footer.copyright.replace('{year}', String(year));
---

<footer class="border-t border-gray-200 bg-white mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href={localePath(locale, '')} class="text-xl font-bold text-gray-900 no-underline">
          Startup Super School
        </a>
        <p class="mt-2 text-sm text-gray-500 max-w-xs">
          {t.footer.tagline}
        </p>
      </div>

      <!-- Learn -->
      <div>
        <h3 class="text-sm font-semibold text-gray-900 tracking-wider uppercase">Learn</h3>
        <ul class="mt-4 space-y-2">
          <li>
            <a href={localePath(locale, 'glossary')} class="text-sm text-gray-500 hover:text-gray-900 no-underline">
              {t.nav.glossary}
            </a>
          </li>
          <li>
            <a href={localePath(locale, 'guides')} class="text-sm text-gray-500 hover:text-gray-900 no-underline">
              {t.nav.guides}
            </a>
          </li>
          <li>
            <a href={localePath(locale, 'concepts')} class="text-sm text-gray-500 hover:text-gray-900 no-underline">
              {t.nav.concepts}
            </a>
          </li>
          <li>
            <a href={localePath(locale, 'articles')} class="text-sm text-gray-500 hover:text-gray-900 no-underline">
              {t.nav.articles}
            </a>
          </li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-sm font-semibold text-gray-900 tracking-wider uppercase">Resources</h3>
        <ul class="mt-4 space-y-2">
          <li>
            <a href="/rss.xml" class="text-sm text-gray-500 hover:text-gray-900 no-underline">
              RSS Feed
            </a>
          </li>
          <li>
            <a href="/sitemap-index.xml" class="text-sm text-gray-500 hover:text-gray-900 no-underline">
              Sitemap
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-gray-200">
      <p class="text-sm text-gray-400">{copyright}</p>
    </div>
  </div>
</footer>
