---
interface Props {
  section: string;
  slug: string;
}
const { section, slug } = Astro.props;
---

<div id="comments-section" class="mt-12 border-t border-gray-200 pt-10"
  data-section={section}
  data-slug={slug}
>
  <!-- Upvote content -->
  <div class="flex items-center gap-4 mb-10">
    <button
      id="content-upvote-btn"
      class="flex items-center gap-2 px-4 py-2 rounded-full border border-gray-300 text-sm font-medium text-gray-600 hover:border-indigo-500 hover:text-indigo-600 transition-colors"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
      </svg>
      <span id="content-vote-count">0</span>
      <span>Upvote</span>
    </button>
    <span id="content-vote-login" class="hidden text-sm text-gray-400">
      <a href="/login" class="text-indigo-600 hover:underline">Log in</a> to upvote
    </span>
  </div>

  <!-- Comments header -->
  <h2 class="text-xl font-bold text-gray-900 mb-6" id="comments-title">Comments</h2>

  <!-- Comment form (shown only when logged in) -->
  <div id="comment-form-wrap" class="hidden mb-8">
    <form id="comment-form" class="space-y-3">
      <textarea
        id="comment-body"
        rows="3"
        maxlength="2000"
        placeholder="Share your thoughts..."
        class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 resize-none"
      ></textarea>
      <input type="hidden" id="comment-parent-id" value="" />
      <div class="flex items-center justify-between">
        <span id="reply-indicator" class="hidden text-sm text-gray-500">
          Replying to a comment - <button type="button" id="cancel-reply" class="text-indigo-600 hover:underline">cancel</button>
        </span>
        <button
          type="submit"
          class="ml-auto px-5 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors"
        >
          Post comment
        </button>
      </div>
    </form>
  </div>

  <!-- Login prompt -->
  <div id="login-prompt" class="mb-8 p-4 bg-gray-50 border border-gray-200 rounded-xl text-sm text-gray-600">
    <a href="/login" class="text-indigo-600 font-medium hover:underline">Log in</a> to join the conversation.
  </div>

  <!-- Comments list -->
  <div id="comments-list" class="space-y-6">
    <p class="text-sm text-gray-400">Loading comments...</p>
  </div>
</div>

<script>
  const section = document.getElementById('comments-section').dataset.section;
  const slug = document.getElementById('comments-section').dataset.slug;
  const contentTargetId = section + '/' + slug;

  let currentUser = null;
  let allComments = [];

  // --- INIT ---
  async function init() {
    const hasSession = Object.keys(localStorage).some(k => k.includes('-auth-token'));
    if (hasSession) {
      const { supabase } = await import('../lib/supabase');
      const { data: { user } } = await supabase.auth.getUser();
      if (user) {
        currentUser = user;
        document.getElementById('comment-form-wrap').classList.remove('hidden');
        document.getElementById('login-prompt').classList.add('hidden');
      }
    }
    await loadVoteCount();
    await loadComments();
    setupUpvoteButton();
    setupCommentForm();
  }

  // --- VOTE COUNT (content) ---
  async function loadVoteCount() {
    const { supabase } = await import('../lib/supabase');
    const { count } = await supabase
      .from('votes')
      .select('*', { count: 'exact', head: true })
      .eq('target_type', 'content')
      .eq('target_id', contentTargetId);
    document.getElementById('content-vote-count').textContent = count ?? 0;

    if (currentUser) {
      const { data } = await supabase
        .from('votes')
        .select('id')
        .eq('target_type', 'content')
        .eq('target_id', contentTargetId)
        .eq('user_id', currentUser.id)
        .maybeSingle();
      if (data) {
        document.getElementById('content-upvote-btn').classList.add('border-indigo-500', 'text-indigo-600');
        document.getElementById('content-upvote-btn').dataset.voted = 'true';
      }
    } else {
      document.getElementById('content-vote-login').classList.remove('hidden');
    }
  }

  function setupUpvoteButton() {
    const btn = document.getElementById('content-upvote-btn');
    btn.addEventListener('click', async () => {
      if (!currentUser) { window.location.href = '/login?next=' + window.location.pathname; return; }
      const { supabase } = await import('../lib/supabase');
      const voted = btn.dataset.voted === 'true';
      const countEl = document.getElementById('content-vote-count');
      if (voted) {
        await supabase.from('votes').delete()
          .eq('target_type', 'content').eq('target_id', contentTargetId).eq('user_id', currentUser.id);
        btn.dataset.voted = 'false';
        btn.classList.remove('border-indigo-500', 'text-indigo-600');
        countEl.textContent = Math.max(0, parseInt(countEl.textContent) - 1);
      } else {
        await supabase.from('votes').insert({ user_id: currentUser.id, target_type: 'content', target_id: contentTargetId });
        btn.dataset.voted = 'true';
        btn.classList.add('border-indigo-500', 'text-indigo-600');
        countEl.textContent = parseInt(countEl.textContent) + 1;
      }
    });
  }

  // --- COMMENTS ---
  async function loadComments() {
    const { supabase } = await import('../lib/supabase');

    const { data: comments } = await supabase
      .from('comments')
      .select('id, user_id, parent_id, body, created_at')
      .eq('section', section)
      .eq('slug', slug)
      .order('created_at', { ascending: true });

    const { data: profiles } = comments?.length
      ? await supabase.from('profiles').select('id, first_name, last_name').in('id', comments.map(c => c.user_id))
      : { data: [] };

    const { data: myVotes } = currentUser
      ? await supabase.from('votes').select('target_id').eq('target_type', 'comment').eq('user_id', currentUser.id)
      : { data: [] };

    const { data: voteCounts } = await supabase
      .from('votes')
      .select('target_id')
      .eq('target_type', 'comment');

    allComments = comments ?? [];
    const profileMap = Object.fromEntries((profiles ?? []).map(p => [p.id, p]));
    const myVoteSet = new Set((myVotes ?? []).map(v => v.target_id));
    const voteCountMap = {};
    for (const v of (voteCounts ?? [])) {
      voteCountMap[v.target_id] = (voteCountMap[v.target_id] ?? 0) + 1;
    }

    renderComments(allComments, profileMap, myVoteSet, voteCountMap);
  }

  function renderComments(comments, profileMap, myVoteSet, voteCountMap) {
    const list = document.getElementById('comments-list');
    const roots = comments.filter(c => !c.parent_id);
    const repliesMap = {};
    for (const c of comments) {
      if (c.parent_id) {
        if (!repliesMap[c.parent_id]) repliesMap[c.parent_id] = [];
        repliesMap[c.parent_id].push(c);
      }
    }

    if (roots.length === 0) {
      list.innerHTML = '<p class="text-sm text-gray-400">No comments yet. Be the first!</p>';
      document.getElementById('comments-title').textContent = 'Comments';
      return;
    }

    document.getElementById('comments-title').textContent = `Comments (${comments.length})`;
    list.innerHTML = roots.map(c => renderComment(c, profileMap, myVoteSet, voteCountMap, repliesMap)).join('');
    attachCommentHandlers(myVoteSet, voteCountMap, profileMap, repliesMap);
  }

  function timeAgo(dateStr) {
    const diff = Math.floor((Date.now() - new Date(dateStr)) / 1000);
    if (diff < 60) return 'just now';
    if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
    if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
    return Math.floor(diff / 86400) + 'd ago';
  }

  function initials(profile) {
    if (!profile) return '?';
    return ((profile.first_name?.[0] ?? '') + (profile.last_name?.[0] ?? '')).toUpperCase() || '?';
  }

  function displayName(profile) {
    if (!profile) return 'Anonymous';
    return [profile.first_name, profile.last_name].filter(Boolean).join(' ') || 'Anonymous';
  }

  function renderComment(c, profileMap, myVoteSet, voteCountMap, repliesMap, isReply = false) {
    const profile = profileMap[c.user_id];
    const voted = myVoteSet.has(c.id);
    const count = voteCountMap[c.id] ?? 0;
    const replies = repliesMap[c.id] ?? [];
    const isOwn = currentUser?.id === c.user_id;

    return `
      <div class="comment-item ${isReply ? 'ml-10 mt-4' : ''}" data-id="${c.id}">
        <div class="flex gap-3">
          <div class="w-8 h-8 rounded-full bg-indigo-100 text-indigo-700 text-xs font-bold flex items-center justify-center shrink-0">
            ${initials(profile)}
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-sm font-semibold text-gray-900">${displayName(profile)}</span>
              <span class="text-xs text-gray-400">${timeAgo(c.created_at)}</span>
              ${isOwn ? `<button class="delete-comment-btn text-xs text-red-400 hover:text-red-600 ml-auto" data-id="${c.id}">delete</button>` : ''}
            </div>
            <p class="text-sm text-gray-700 whitespace-pre-wrap break-words">${escapeHtml(c.body)}</p>
            <div class="flex items-center gap-4 mt-2">
              <button class="vote-comment-btn flex items-center gap-1 text-xs ${voted ? 'text-indigo-600 font-semibold' : 'text-gray-400 hover:text-indigo-600'} transition-colors" data-id="${c.id}" data-voted="${voted}">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
                </svg>
                <span class="vote-count-${c.id}">${count}</span>
              </button>
              ${!isReply && currentUser ? `<button class="reply-btn text-xs text-gray-400 hover:text-indigo-600 transition-colors" data-id="${c.id}" data-name="${displayName(profile)}">Reply</button>` : ''}
            </div>
            ${replies.map(r => renderComment(r, profileMap, myVoteSet, voteCountMap, repliesMap, true)).join('')}
          </div>
        </div>
      </div>
    `;
  }

  function escapeHtml(str) {
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function attachCommentHandlers(myVoteSet, voteCountMap, profileMap, repliesMap) {
    // Vote on comment
    document.querySelectorAll('.vote-comment-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!currentUser) { window.location.href = '/login?next=' + window.location.pathname; return; }
        const id = btn.dataset.id;
        const voted = btn.dataset.voted === 'true';
        const { supabase } = await import('../lib/supabase');
        const countEl = document.querySelector(`.vote-count-${id}`);
        if (voted) {
          await supabase.from('votes').delete().eq('target_type', 'comment').eq('target_id', id).eq('user_id', currentUser.id);
          btn.dataset.voted = 'false';
          btn.classList.remove('text-indigo-600', 'font-semibold');
          btn.classList.add('text-gray-400');
          countEl.textContent = Math.max(0, parseInt(countEl.textContent) - 1);
        } else {
          await supabase.from('votes').insert({ user_id: currentUser.id, target_type: 'comment', target_id: id });
          btn.dataset.voted = 'true';
          btn.classList.add('text-indigo-600', 'font-semibold');
          btn.classList.remove('text-gray-400');
          countEl.textContent = parseInt(countEl.textContent) + 1;
        }
      });
    });

    // Reply button
    document.querySelectorAll('.reply-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.getElementById('comment-parent-id').value = btn.dataset.id;
        document.getElementById('reply-indicator').classList.remove('hidden');
        document.getElementById('comment-body').focus();
      });
    });

    // Cancel reply
    document.getElementById('cancel-reply')?.addEventListener('click', () => {
      document.getElementById('comment-parent-id').value = '';
      document.getElementById('reply-indicator').classList.add('hidden');
    });

    // Delete comment
    document.querySelectorAll('.delete-comment-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('Delete this comment?')) return;
        const { supabase } = await import('../lib/supabase');
        await supabase.from('comments').delete().eq('id', btn.dataset.id).eq('user_id', currentUser.id);
        await loadComments();
      });
    });
  }

  function setupCommentForm() {
    const form = document.getElementById('comment-form');
    if (!form) return;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!currentUser) return;
      const body = document.getElementById('comment-body').value.trim();
      if (!body) return;
      const parentId = document.getElementById('comment-parent-id').value || null;
      const { supabase } = await import('../lib/supabase');
      const { error } = await supabase.from('comments').insert({
        user_id: currentUser.id,
        section,
        slug,
        parent_id: parentId,
        body,
      });
      if (!error) {
        document.getElementById('comment-body').value = '';
        document.getElementById('comment-parent-id').value = '';
        document.getElementById('reply-indicator').classList.add('hidden');
        await loadComments();
      }
    });
  }

  init();
</script>
