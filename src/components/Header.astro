---
import { getTranslations, localePath } from '../utils/i18n';
import type { Locale } from '../utils/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const navLinks = [
  { href: '/ai', label: 'AI', highlight: true },
  { href: localePath(locale, 'curriculum'), label: 'Curriculum' },
  { href: localePath(locale, 'glossary'), label: t.nav.glossary },
  { href: localePath(locale, 'guides'), label: t.nav.guides },
  { href: localePath(locale, 'concepts'), label: t.nav.concepts },
  { href: localePath(locale, 'articles'), label: t.nav.articles },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-gray-200 bg-white sticky top-0 z-40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a
        href={localePath(locale, '')}
        class="flex items-center gap-2 no-underline text-gray-900 hover:text-indigo-600 transition-colors"
      >
        <span class="text-2xl font-bold tracking-tight">
          <span class="text-indigo-600">S</span>tartup
          <span class="text-indigo-600">S</span>uper
          <span class="text-indigo-600">S</span>chool
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-6" aria-label="Main navigation">
        {navLinks.map(({ href, label, highlight }) => (
          <a
            href={href}
            class:list={[
              'text-sm font-medium no-underline transition-colors',
              currentPath === href || (href !== '/ai' && currentPath.startsWith(href))
                ? 'text-indigo-600'
                : highlight
                  ? 'text-indigo-600 hover:text-indigo-800'
                  : 'text-gray-600 hover:text-gray-900',
            ]}
          >
            {label}
          </a>
        ))}
        <!-- Auth nav (populated by JS) -->
        <div class="w-px h-4 bg-gray-200"></div>
        <div id="header-auth" class="flex items-center gap-4">
          <a id="auth-login-link" href="/login" class="hidden text-sm font-medium text-gray-600 hover:text-gray-900 no-underline transition-colors">Log in</a>
          <a id="auth-register-link" href="/register" class="hidden text-sm font-medium px-4 py-1.5 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors no-underline">Sign up</a>
          <a id="auth-profile-link" href="/profile" class="hidden text-sm font-medium text-gray-600 hover:text-indigo-600 no-underline transition-colors truncate max-w-[140px]"></a>
          <button id="auth-logout-btn" class="hidden text-sm text-gray-400 hover:text-gray-600 transition-colors">Log out</button>
        </div>
      </nav>

      <!-- Mobile menu button -->
      <button
        type="button"
        class="md:hidden inline-flex items-center justify-center p-2 rounded-md text-gray-600 hover:text-gray-900 hover:bg-gray-100 focus:outline-none"
        aria-label="Toggle menu"
        id="mobile-menu-button"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <div class="md:hidden hidden border-t border-gray-200" id="mobile-menu">
    <nav class="px-4 py-3 space-y-1">
      {navLinks.map(({ href, label, highlight }) => (
        <a
          href={href}
          class:list={[
            'block px-3 py-2 rounded-md text-sm font-medium no-underline',
            currentPath === href || (href !== '/ai' && currentPath.startsWith(href))
              ? 'bg-indigo-50 text-indigo-600'
              : highlight
                ? 'text-indigo-600 hover:bg-indigo-50'
                : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900',
          ]}
        >
          {label}
        </a>
      ))}
      <a href={localePath(locale, 'search')} class="flex items-center gap-2 px-3 py-2 text-sm text-gray-600 hover:text-gray-900 no-underline">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 1 0 5.197 5.197a7.5 7.5 0 0 0 10.606 10.606z" />
        </svg>
        Search
      </a>
      <div class="px-3 pt-2 border-t border-gray-100 flex gap-3">
        <a id="mobile-auth-login" href="/login" class="hidden text-sm font-medium text-gray-600 no-underline">Log in</a>
        <a id="mobile-auth-register" href="/register" class="hidden text-sm font-medium text-indigo-600 no-underline">Sign up</a>
        <a id="mobile-auth-profile" href="/profile" class="hidden text-sm font-medium text-gray-600 no-underline"></a>
        <button id="mobile-auth-logout" class="hidden text-sm text-gray-400">Log out</button>
      </div>
    </nav>
  </div>
</header>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  button?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>

<script>
  // Fast path: if no Supabase session token in localStorage, skip loading the SDK entirely
  const hasSession = Object.keys(localStorage).some(k => k.includes('-auth-token'));

  if (!hasSession) {
    document.getElementById('auth-login-link')?.classList.remove('hidden');
    document.getElementById('auth-register-link')?.classList.remove('hidden');
    document.getElementById('mobile-auth-login')?.classList.remove('hidden');
    document.getElementById('mobile-auth-register')?.classList.remove('hidden');
  } else {
    const { supabase } = await import('../lib/supabase');
    const { data: { user } } = await supabase.auth.getUser();

    if (user) {
      const { data: profile } = await supabase.from('profiles').select('first_name').eq('id', user.id).maybeSingle();
      const displayName = profile?.first_name || user.email?.split('@')[0] || 'My account';

      const profileLink = document.getElementById('auth-profile-link');
      if (profileLink) { profileLink.textContent = displayName; profileLink.classList.remove('hidden'); }
      document.getElementById('auth-logout-btn')?.classList.remove('hidden');

      const mobileProfile = document.getElementById('mobile-auth-profile');
      if (mobileProfile) { mobileProfile.textContent = displayName; mobileProfile.classList.remove('hidden'); }
      document.getElementById('mobile-auth-logout')?.classList.remove('hidden');
    } else {
      document.getElementById('auth-login-link')?.classList.remove('hidden');
      document.getElementById('auth-register-link')?.classList.remove('hidden');
      document.getElementById('mobile-auth-login')?.classList.remove('hidden');
      document.getElementById('mobile-auth-register')?.classList.remove('hidden');
    }

    async function logout() {
      await supabase.auth.signOut();
      window.location.href = '/';
    }
    document.getElementById('auth-logout-btn')?.addEventListener('click', logout);
    document.getElementById('mobile-auth-logout')?.addEventListener('click', logout);
  }
</script>
