---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import { getCollection } from 'astro:content';
import { getTranslations } from '../../utils/i18n';

const locale = 'en' as const;
const t = getTranslations(locale);

const [glossaryEntries, guidesEntries, conceptsEntries, articlesEntries] = await Promise.all([
  getCollection('glossary', ({ data }) => data.locale === locale && data.published !== false),
  getCollection('guides', ({ data }) => data.locale === locale && data.published !== false),
  getCollection('concepts', ({ data }) => data.locale === locale && data.published !== false),
  getCollection('articles', ({ data }) => data.locale === locale && data.published !== false),
]);

// Show 4 featured items from each section
const featured = {
  glossary: glossaryEntries.slice(0, 4),
  guides: guidesEntries.slice(0, 3),
  concepts: conceptsEntries.slice(0, 3),
  articles: articlesEntries.slice(0, 2),
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: t.site.name,
  description: t.site.description,
  url: Astro.site?.href,
};
---

<BaseLayout
  title="Home"
  description={t.site.description}
  locale={locale}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-indigo-50 to-white border-b border-gray-100 py-20 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 leading-tight mb-4">
        {t.home.hero.headline}
      </h1>
      <p class="text-xl text-gray-600 leading-relaxed mb-8">
        {t.home.hero.subheadline}
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a
          href={`/${locale}/glossary`}
          class="inline-flex items-center px-6 py-3 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition-colors no-underline"
        >
          Browse Glossary
        </a>
        <a
          href={`/${locale}/guides`}
          class="inline-flex items-center px-6 py-3 bg-white text-gray-700 font-medium rounded-lg border border-gray-300 hover:border-gray-400 transition-colors no-underline"
        >
          Read Guides
        </a>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <!-- Glossary featured -->
    <section>
      <div class="flex items-center justify-between mb-6">
        <div>
          <h2 class="text-2xl font-bold text-gray-900">{t.home.sections.glossaryTitle}</h2>
          <p class="text-gray-500 mt-1">{t.content.sectionDescriptions.glossary}</p>
        </div>
        <a href={`/${locale}/glossary`} class="text-sm text-indigo-600 hover:text-indigo-800 font-medium no-underline">
          View all →
        </a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {featured.glossary.map((entry) => {
          const slug = entry.slug.split('/').pop();
          return (
            <div class="relative">
              <ContentCard
                title={entry.data.title}
                description={entry.data.description}
                href={`/${locale}/glossary/${slug}`}
                difficulty={entry.data.difficulty}
                category={entry.data.category}
                tags={entry.data.tags}
                locale={locale}
              />
            </div>
          );
        })}
      </div>
    </section>

    <!-- Guides featured -->
    <section>
      <div class="flex items-center justify-between mb-6">
        <div>
          <h2 class="text-2xl font-bold text-gray-900">{t.home.sections.guidesTitle}</h2>
          <p class="text-gray-500 mt-1">{t.content.sectionDescriptions.guides}</p>
        </div>
        <a href={`/${locale}/guides`} class="text-sm text-indigo-600 hover:text-indigo-800 font-medium no-underline">
          View all →
        </a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {featured.guides.map((entry) => {
          const slug = entry.slug.split('/').pop();
          return (
            <div class="relative">
              <ContentCard
                title={entry.data.title}
                description={entry.data.description}
                href={`/${locale}/guides/${slug}`}
                difficulty={entry.data.difficulty}
                category={entry.data.category}
                tags={entry.data.tags}
                locale={locale}
                readingTime={'readingTime' in entry.data ? entry.data.readingTime : undefined}
              />
            </div>
          );
        })}
      </div>
    </section>

    <!-- Concepts featured -->
    <section>
      <div class="flex items-center justify-between mb-6">
        <div>
          <h2 class="text-2xl font-bold text-gray-900">{t.home.sections.conceptsTitle}</h2>
          <p class="text-gray-500 mt-1">{t.content.sectionDescriptions.concepts}</p>
        </div>
        <a href={`/${locale}/concepts`} class="text-sm text-indigo-600 hover:text-indigo-800 font-medium no-underline">
          View all →
        </a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {featured.concepts.map((entry) => {
          const slug = entry.slug.split('/').pop();
          return (
            <div class="relative">
              <ContentCard
                title={entry.data.title}
                description={entry.data.description}
                href={`/${locale}/concepts/${slug}`}
                difficulty={entry.data.difficulty}
                category={entry.data.category}
                tags={entry.data.tags}
                locale={locale}
              />
            </div>
          );
        })}
      </div>
    </section>

    <!-- Articles featured -->
    <section>
      <div class="flex items-center justify-between mb-6">
        <div>
          <h2 class="text-2xl font-bold text-gray-900">{t.home.sections.articlesTitle}</h2>
          <p class="text-gray-500 mt-1">{t.content.sectionDescriptions.articles}</p>
        </div>
        <a href={`/${locale}/articles`} class="text-sm text-indigo-600 hover:text-indigo-800 font-medium no-underline">
          View all →
        </a>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {featured.articles.map((entry) => {
          const slug = entry.slug.split('/').pop();
          return (
            <div class="relative">
              <ContentCard
                title={entry.data.title}
                description={entry.data.description}
                href={`/${locale}/articles/${slug}`}
                difficulty={entry.data.difficulty}
                category={entry.data.category}
                tags={entry.data.tags}
                locale={locale}
                readingTime={'readingTime' in entry.data ? entry.data.readingTime : undefined}
              />
            </div>
          );
        })}
      </div>
    </section>

  </div>
</BaseLayout>
