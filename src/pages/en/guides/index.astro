---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ContentCard from '../../../components/ContentCard.astro';
import { getCollection } from 'astro:content';
import { getTranslations } from '../../../utils/i18n';

const locale = 'en' as const;
const t = getTranslations(locale);

const entries = await getCollection('guides', ({ data }) => {
  return data.locale === locale && data.published !== false;
});

const sorted = entries.sort(
  (a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf(),
);
---

<BaseLayout
  title="Guides"
  description={t.content.sectionDescriptions.guides}
  locale={locale}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <header class="mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-3">{t.nav.guides}</h1>
      <p class="text-xl text-gray-600">{t.content.sectionDescriptions.guides}</p>
    </header>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {sorted.map((entry) => {
        const slug = entry.slug.split('/').pop();
        return (
          <div class="relative">
            <ContentCard
              title={entry.data.title}
              description={entry.data.description}
              href={`/${locale}/guides/${slug}`}
              difficulty={entry.data.difficulty}
              category={entry.data.category}
              tags={entry.data.tags}
              locale={locale}
              readingTime={entry.data.readingTime}
            />
          </div>
        );
      })}
    </div>
  </div>
</BaseLayout>
