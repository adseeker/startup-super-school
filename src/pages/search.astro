---
import BaseLayout from '../layouts/BaseLayout.astro';

const locale = 'en' as const;
---

<BaseLayout
  title="Search"
  description="Search glossary terms, guides, concepts and articles on Startup Super School."
  locale={locale}
>
  <link slot="head" rel="stylesheet" href="/pagefind/pagefind-ui.css" />

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Search results</h1>
    </header>
    <div id="search"></div>
  </div>

  <script>
    import { PagefindUI } from '@pagefind/default-ui';

    function initSearch() {
      // Read query client-side — Astro.url has no searchParams at static build time
      const query = new URLSearchParams(window.location.search).get('q') ?? '';
      new PagefindUI({
        element: '#search',
        showSubResults: true,
        defaultValue: query,
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSearch);
    } else {
      initSearch();
    }
  </script>
</BaseLayout>
