---
import ContentLayout from '../../layouts/ContentLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('glossary', ({ data }) => {
    return data.locale === 'en' && data.published !== false;
  });
  return entries.map((entry) => ({
    params: { slug: entry.slug.split('/').pop() },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();
const { title, description, locale, category, tags, difficulty, publishedDate, lastUpdated, seoKeywords, video, faqs } =
  entry.data;
const slug = entry.slug.split('/').pop()!;
---

<ContentLayout
  title={title}
  description={description}
  locale={locale}
  category={category}
  tags={tags}
  difficulty={difficulty}
  publishedDate={publishedDate}
  lastUpdated={lastUpdated}
  headings={headings}
  sectionSlug="glossary"
  seoKeywords={seoKeywords}
  canonicalUrl={Astro.url.href}
  slug={slug}
  video={video}
  faqs={faqs}
>
  <Content />
</ContentLayout>
