---
export const prerender = false;

import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { supabase } from '../../../../lib/supabase';

const { username, id } = Astro.params;

// Fetch note by ID
const { data: note } = await supabase
  .from('notes')
  .select('id, body, created_at, user_id')
  .eq('id', id)
  .maybeSingle();

if (!note) {
  return Astro.redirect('/404');
}

// Fetch author profile and verify username matches
const { data: profile } = await supabase
  .from('profiles')
  .select('id, username, first_name, last_name, bio, job_title, company, avatar_url')
  .eq('id', note.user_id)
  .maybeSingle();

// Guard: wrong username in URL → canonical redirect
if (!profile || profile.username !== username) {
  if (profile?.username) {
    return Astro.redirect(`/@${profile.username}/notes/${id}`, 301);
  }
  return Astro.redirect('/404');
}

const displayName = [profile.first_name, profile.last_name].filter(Boolean).join(' ') || username || 'User';

function timeAgo(iso: string): string {
  const diff = Date.now() - new Date(iso).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1)  return 'just now';
  if (mins < 60) return `${mins}m ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24)  return `${hrs}h ago`;
  const days = Math.floor(hrs / 24);
  if (days < 30) return `${days}d ago`;
  return new Date(iso).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}

const publishedDate = new Date(note.created_at);
const excerpt = note.body.slice(0, 120) + (note.body.length > 120 ? '…' : '');
---

<BaseLayout
  title={`Note by @${username}`}
  description={excerpt}
  locale="en"
  noindex={true}
  publishedDate={publishedDate}
>
  <div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-6">

    <!-- Note card -->
    <div class="bg-white rounded-2xl border border-gray-200 p-6 sm:p-8">
      <p class="text-base text-gray-900 whitespace-pre-wrap leading-relaxed">{note.body}</p>
      <p class="text-xs text-gray-400 mt-4">{timeAgo(note.created_at)}</p>
    </div>

    <!-- Author -->
    <div class="flex items-center gap-3">
      <div class="shrink-0 w-10 h-10 rounded-full bg-indigo-100 flex items-center justify-center font-bold text-indigo-600 text-sm select-none">
        {displayName.charAt(0).toUpperCase()}
      </div>
      <div>
        <a href={`/u/${username}`} class="text-sm font-semibold text-gray-900 hover:text-indigo-600 no-underline transition-colors">
          {displayName}
        </a>
        <p class="text-xs text-gray-400">@{username}{profile.job_title ? ` · ${profile.job_title}` : ''}</p>
      </div>
    </div>

    <!-- Back + site link -->
    <div class="flex items-center justify-between">
      <a href={`/u/${username}`} class="text-xs text-gray-400 hover:text-gray-700 no-underline transition-colors">
        ← All notes by @{username}
      </a>
      <a href="/" class="text-xs text-indigo-500 hover:text-indigo-700 no-underline">
        Startup Super School
      </a>
    </div>

  </div>
</BaseLayout>
