---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../lib/supabase';

const { username } = Astro.params;

// Fetch profile by username
const { data: profile } = await supabase
  .from('profiles')
  .select('id, username, first_name, last_name, bio, job_title, company, avatar_url, twitter_url, linkedin_url, website_url')
  .eq('username', username)
  .maybeSingle();

if (!profile) {
  return Astro.redirect('/404');
}

// Fetch public notes
const { data: notes } = await supabase
  .from('notes')
  .select('id, body, created_at')
  .eq('user_id', profile.id)
  .order('created_at', { ascending: false })
  .limit(50);

const displayName = [profile.first_name, profile.last_name].filter(Boolean).join(' ') || username;
const noteList = notes ?? [];

function timeAgo(iso: string): string {
  const diff = Date.now() - new Date(iso).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1)  return 'just now';
  if (mins < 60) return `${mins}m ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24)  return `${hrs}h ago`;
  const days = Math.floor(hrs / 24);
  if (days < 30) return `${days}d ago`;
  return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout
  title={`@${username}`}
  description={profile.bio ?? `${displayName}'s profile on Startup Super School.`}
  locale="en"
  noindex={true}
>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-8">

    <!-- Profile card -->
    <div class="bg-white rounded-2xl border border-gray-200 p-6 sm:p-8">
      <div class="flex items-start gap-5">

        <!-- Avatar placeholder -->
        <div class="shrink-0 w-16 h-16 rounded-full bg-indigo-100 flex items-center justify-center text-2xl font-bold text-indigo-600 select-none">
          {displayName.charAt(0).toUpperCase()}
        </div>

        <div class="flex-1 min-w-0">
          <h1 class="text-xl font-bold text-gray-900">{displayName}</h1>
          <p class="text-sm text-gray-400">@{username}</p>

          {(profile.job_title || profile.company) && (
            <p class="text-sm text-gray-600 mt-1">
              {profile.job_title}{profile.job_title && profile.company ? ' · ' : ''}{profile.company}
            </p>
          )}

          {profile.bio && (
            <p class="text-sm text-gray-700 mt-3 leading-relaxed">{profile.bio}</p>
          )}

          <!-- Social links -->
          <div class="flex items-center gap-4 mt-4 flex-wrap">
            {profile.website_url && (
              <a href={profile.website_url} target="_blank" rel="noopener noreferrer"
                class="text-xs text-gray-500 hover:text-indigo-600 no-underline transition-colors">
                🌐 {profile.website_url.replace(/^https?:\/\//, '')}
              </a>
            )}
            {profile.twitter_url && (
              <a href={`https://x.com/${profile.twitter_url}`} target="_blank" rel="noopener noreferrer"
                class="text-xs text-gray-500 hover:text-gray-900 no-underline transition-colors">
                𝕏 @{profile.twitter_url}
              </a>
            )}
            {profile.linkedin_url && (
              <a href={`https://linkedin.com/in/${profile.linkedin_url}`} target="_blank" rel="noopener noreferrer"
                class="text-xs text-gray-500 hover:text-blue-600 no-underline transition-colors">
                in/{profile.linkedin_url}
              </a>
            )}
          </div>
        </div>
      </div>
    </div>

    <!-- Notes feed -->
    <div>
      <h2 class="text-base font-semibold text-gray-900 mb-4">
        Notes
        {noteList.length > 0 && <span class="text-sm font-normal text-gray-400 ml-2">{noteList.length}</span>}
      </h2>

      {noteList.length === 0 ? (
        <p class="text-sm text-gray-400">No notes yet.</p>
      ) : (
        <div class="space-y-3">
          {noteList.map(note => (
            <a
              href={`/u/${username}/notes/${note.id}`}
              class="block bg-white rounded-xl border border-gray-200 p-4 hover:border-indigo-200 hover:shadow-sm transition-all no-underline group"
            >
              <p class="text-sm text-gray-800 whitespace-pre-wrap leading-relaxed">{note.body}</p>
              <p class="text-xs text-gray-400 mt-2 group-hover:text-indigo-400 transition-colors">
                {timeAgo(note.created_at)}
              </p>
            </a>
          ))}
        </div>
      )}
    </div>

    <!-- Footer link -->
    <p class="text-xs text-gray-400 text-center">
      Shared from <a href="/" class="text-indigo-500 hover:text-indigo-700 no-underline">Startup Super School</a>
    </p>

  </div>
</BaseLayout>
