---
import BaseLayout from './BaseLayout.astro';
import { existsSync } from 'fs';
import { join } from 'path';
import DifficultyBadge from '../components/DifficultyBadge.astro';
import TableOfContents from '../components/TableOfContents.astro';
import RelatedContent from '../components/RelatedContent.astro';
import { getTranslations, formatDate, localePath, slugifyTag } from '../utils/i18n';
import type { Locale } from '../utils/i18n';
import type { MarkdownHeading } from 'astro';
import { getCollection } from 'astro:content';
import { CURRICULUM_TRACKS, getTrackForContent } from '../data/curriculum';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  category: string;
  tags: string[];
  difficulty: 'beginner' | 'intermediate' | 'advanced';
  publishedDate: Date;
  lastUpdated?: Date;
  readingTime?: number;
  headings: MarkdownHeading[];
  sectionSlug: 'glossary' | 'guides' | 'concepts' | 'articles';
  seoKeywords?: string[];
  relatedSlugs?: string[];
  canonicalUrl?: string;
  ogImage?: string;
  slug?: string;
  video?: boolean;
  faqs?: Array<{ question: string; answer: string }>;
  steps?: Array<{ name: string; text: string }>;
}

const {
  title,
  description,
  locale,
  category,
  tags,
  difficulty,
  publishedDate,
  lastUpdated,
  readingTime,
  headings,
  sectionSlug,
  seoKeywords,
  canonicalUrl,
  ogImage,
  slug,
  video,
  faqs,
  steps,
} = Astro.props;

const t = getTranslations(locale);
const siteUrl = Astro.site?.href?.replace(/\/$/, '') ?? '';

// ── Find next item in curriculum track ─────────────────────────────────
type NextItem = { title: string; href: string; section: string; readingTime?: number } | null;
let nextItem: NextItem = null;

if (slug) {
  const trackSlug = getTrackForContent(category, tags);
  if (trackSlug) {
    const track = CURRICULUM_TRACKS.find(t => t.slug === trackSlug)!;

    const [glossary, guides, concepts, articles] = await Promise.all([
      getCollection('glossary', ({ data }) => data.published !== false),
      getCollection('guides', ({ data }) => data.published !== false),
      getCollection('concepts', ({ data }) => data.published !== false),
      getCollection('articles', ({ data }) => data.published !== false),
    ]);

    type FlatItem = { section: string; slug: string; title: string; difficulty: string; readingTime?: number; category: string; tags: string[] };
    const allItems: FlatItem[] = [
      ...glossary.map(e => ({ section: 'glossary', slug: e.slug.split('/').pop()!, title: e.data.title, difficulty: e.data.difficulty, category: e.data.category, tags: e.data.tags })),
      ...guides.map(e => ({ section: 'guides', slug: e.slug.split('/').pop()!, title: e.data.title, difficulty: e.data.difficulty, category: e.data.category, tags: e.data.tags, readingTime: 'readingTime' in e.data ? (e.data.readingTime as number | undefined) : undefined })),
      ...concepts.map(e => ({ section: 'concepts', slug: e.slug.split('/').pop()!, title: e.data.title, difficulty: e.data.difficulty, category: e.data.category, tags: e.data.tags })),
      ...articles.map(e => ({ section: 'articles', slug: e.slug.split('/').pop()!, title: e.data.title, difficulty: e.data.difficulty, category: e.data.category, tags: e.data.tags, readingTime: 'readingTime' in e.data ? (e.data.readingTime as number | undefined) : undefined })),
    ];

    const diffOrder: Record<string, number> = { beginner: 0, intermediate: 1, advanced: 2 };
    const trackItems = allItems
      .filter(item => getTrackForContent(item.category, item.tags) === track.slug)
      .sort((a, b) => (diffOrder[a.difficulty] ?? 0) - (diffOrder[b.difficulty] ?? 0));

    const currentIdx = trackItems.findIndex(item => item.section === sectionSlug && item.slug === slug);
    if (currentIdx !== -1 && currentIdx < trackItems.length - 1) {
      const next = trackItems[currentIdx + 1];
      nextItem = {
        title: next.title,
        href: `/${next.section}/${next.slug}`,
        section: next.section,
        readingTime: next.readingTime,
      };
    }
  }
}

// Auto-detect infographic
const hasInfographic = slug
  ? existsSync(join(process.cwd(), 'public', 'infographics', sectionSlug, `${slug}.svg`))
  : false;

// Per-type JSON-LD schema
const jsonLd = sectionSlug === 'glossary'
  ? {
      '@context': 'https://schema.org',
      '@type': 'DefinedTerm',
      name: title,
      description,
      inLanguage: locale,
      inDefinedTermSet: {
        '@type': 'DefinedTermSet',
        name: `${t.site.name} Glossary`,
        url: `${siteUrl}${localePath(locale, 'glossary')}`,
      },
    }
  : sectionSlug === 'guides'
  ? {
      '@context': 'https://schema.org',
      '@type': 'HowTo',
      name: title,
      description,
      inLanguage: locale,
      datePublished: publishedDate.toISOString(),
      ...(lastUpdated ? { dateModified: lastUpdated.toISOString() } : {}),
      estimatedCost: { '@type': 'MonetaryAmount', currency: 'USD', value: '0' },
      ...(steps && steps.length > 0
        ? {
            step: steps.map((s, i) => ({
              '@type': 'HowToStep',
              position: i + 1,
              name: s.name,
              text: s.text,
            })),
          }
        : {}),
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: title,
      description,
      inLanguage: locale,
      datePublished: publishedDate.toISOString(),
      ...(lastUpdated ? { dateModified: lastUpdated.toISOString() } : {}),
      publisher: {
        '@type': 'Organization',
        name: t.site.name,
        url: siteUrl,
      },
    };

// FAQPage JSON-LD (generated when faqs frontmatter is present)
const faqLd = faqs && faqs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: faq.answer,
        },
      })),
    }
  : null;

// BreadcrumbList JSON-LD
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: t.nav.home,
      item: `${siteUrl}${localePath(locale, '')}`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: t.content.sections[sectionSlug],
      item: `${siteUrl}${localePath(locale, sectionSlug)}`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: title,
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  type="article"
  publishedDate={publishedDate}
  lastUpdated={lastUpdated}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
  jsonLd={jsonLd}
>
  <!-- Extra JSON-LD: BreadcrumbList -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  <!-- Extra JSON-LD: FAQPage (only when faqs frontmatter is present) -->
  {faqLd && <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqLd)} />}

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
      <a href={localePath(locale, '')} class="hover:text-gray-700 no-underline">{t.nav.home}</a>
      <span class="mx-2">›</span>
      <a href={localePath(locale, sectionSlug)} class="hover:text-gray-700 capitalize no-underline">
        {t.content.sections[sectionSlug]}
      </a>
      <span class="mx-2">›</span>
      <span class="text-gray-900">{title}</span>
    </nav>

    <div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-12">
      <!-- Main content -->
      <article>
        <!-- Video intro (optional) -->
        {video && slug && (
          <div class="mb-8 rounded-xl overflow-hidden shadow-sm" data-pagefind-ignore>
            <video
              src={`/videos/${sectionSlug}/${slug}.mp4`}
              controls
              preload="metadata"
              class="w-full aspect-video"
              aria-label={`Video introduction: ${title}`}
            />
          </div>
        )}

        <!-- Header -->
        <header class="mb-8">
          <div class="flex flex-wrap items-center gap-3 mb-4">
            <DifficultyBadge difficulty={difficulty} locale={locale} />
            <span class="text-sm text-gray-500 capitalize">{category}</span>
            {readingTime && (
              <span class="text-sm text-gray-500">
                {t.content.readingTime.replace('{n}', String(readingTime))}
              </span>
            )}
          </div>
          <h1 data-pagefind-meta="title" class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight mb-4">
            {title}
          </h1>
          <p class="text-xl text-gray-600 leading-relaxed">{description}</p>
          <div class="mt-4 flex flex-wrap gap-2 text-xs text-gray-500">
            <span>{t.content.publishedOn.replace('{date}', formatDate(publishedDate, locale))}</span>
            {lastUpdated && (
              <span>
                · {t.content.lastUpdated.replace('{date}', formatDate(lastUpdated, locale))}
              </span>
            )}
          </div>
          <!-- Compact share row -->
          <div class="mt-3 flex flex-wrap items-center gap-1.5" data-share-container data-share-url={`${siteUrl}/${sectionSlug}/${slug}`} data-share-title={title}>
            <span class="text-xs text-gray-400 mr-0.5">Share:</span>
            <a data-share-whatsapp href="#" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md border border-gray-200 text-xs text-gray-500 hover:bg-green-50 hover:text-green-700 hover:border-green-200 transition-colors no-underline">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.532 5.847L.044 23.956l6.256-1.47A11.93 11.93 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.885 0-3.647-.52-5.153-1.42l-.369-.219-3.822.898.944-3.717-.241-.383A9.943 9.943 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
              WhatsApp
            </a>
            <a data-share-telegram href="#" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md border border-gray-200 text-xs text-gray-500 hover:bg-sky-50 hover:text-sky-700 hover:border-sky-200 transition-colors no-underline">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.248-2.029 9.562c-.148.658-.538.817-1.09.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12l-6.871 4.326-2.962-.924c-.643-.204-.657-.643.136-.953l11.57-4.461c.537-.194 1.006.131.898.659z"/></svg>
              Telegram
            </a>
            <a data-share-email href="#"
              class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md border border-gray-200 text-xs text-gray-500 hover:bg-indigo-50 hover:text-indigo-700 hover:border-indigo-200 transition-colors no-underline">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              Email
            </a>
            <button data-share-copy
              class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md border border-gray-200 text-xs text-gray-500 hover:bg-gray-100 hover:text-gray-700 transition-colors">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              <span data-share-label>Copy link</span>
            </button>
          </div>
        </header>

        <!-- Infographic (auto-detected when file exists in public/infographics/) -->
        {hasInfographic && slug && (
          <div class="mb-8 not-prose" data-pagefind-ignore>
            <img
              src={`/infographics/${sectionSlug}/${slug}.svg`}
              alt={`Visual summary of ${title}`}
              class="w-full rounded-xl border border-gray-100 shadow-sm"
              loading="lazy"
              width="900"
            />
          </div>
        )}

        <!-- Article body -->
        <div
          data-pagefind-body
          class="prose prose-gray prose-lg max-w-none
          prose-headings:font-semibold prose-headings:text-gray-900
          prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
          prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
          prose-p:text-gray-700 prose-p:leading-relaxed
          prose-a:text-indigo-600 prose-a:no-underline hover:prose-a:underline
          prose-strong:text-gray-900
          prose-blockquote:border-indigo-400 prose-blockquote:text-gray-600
          prose-code:text-indigo-700 prose-code:bg-indigo-50 prose-code:px-1 prose-code:rounded
          prose-pre:bg-gray-900 prose-pre:text-gray-100
          prose-table:text-sm
          prose-th:text-left prose-th:font-semibold
          prose-img:rounded-lg">
          <slot />
        </div>

        <!-- FAQ section -->
        {faqs && faqs.length > 0 && (
          <div class="mt-12 pt-8 border-t border-gray-200">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Frequently Asked Questions</h2>
            <dl class="space-y-4">
              {faqs.map((faq) => (
                <details class="group border border-gray-200 rounded-xl overflow-hidden">
                  <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer list-none font-semibold text-gray-900 hover:bg-gray-50 transition-colors">
                    {faq.question}
                    <svg class="w-5 h-5 text-gray-400 shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                    </svg>
                  </summary>
                  <div class="px-5 pb-5 pt-1 text-gray-600 leading-relaxed text-[15px]">
                    {faq.answer}
                  </div>
                </details>
              ))}
            </dl>
          </div>
        )}

        <!-- Tags -->
        {tags.length > 0 && (
          <div class="mt-10 pt-6 border-t border-gray-200">
            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <a
                  href={localePath(locale, `tags/${slugifyTag(tag)}`)}
                  class="inline-flex items-center px-3 py-1 rounded-full text-sm bg-gray-100 text-gray-700 hover:bg-indigo-50 hover:text-indigo-600 transition-colors no-underline"
                >
                  {tag}
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Share with your team -->
        <div class="mt-8 pt-6 border-t border-gray-200" data-share-container data-share-url={`${siteUrl}/${sectionSlug}/${slug}`} data-share-title={title}>
          <p class="text-sm font-semibold text-gray-700 mb-3">Share with your team</p>
          <div class="flex flex-wrap gap-2">
            <!-- WhatsApp -->
            <a data-share-whatsapp href="#" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-gray-200 text-sm text-gray-600 hover:bg-green-50 hover:text-green-700 hover:border-green-200 transition-colors no-underline">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.532 5.847L.044 23.956l6.256-1.47A11.93 11.93 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.885 0-3.647-.52-5.153-1.42l-.369-.219-3.822.898.944-3.717-.241-.383A9.943 9.943 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
              WhatsApp
            </a>
            <!-- Telegram -->
            <a data-share-telegram href="#" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-gray-200 text-sm text-gray-600 hover:bg-sky-50 hover:text-sky-700 hover:border-sky-200 transition-colors no-underline">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.248-2.029 9.562c-.148.658-.538.817-1.09.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12l-6.871 4.326-2.962-.924c-.643-.204-.657-.643.136-.953l11.57-4.461c.537-.194 1.006.131.898.659z"/></svg>
              Telegram
            </a>
            <!-- Email -->
            <a data-share-email href="#"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-gray-200 text-sm text-gray-600 hover:bg-indigo-50 hover:text-indigo-700 hover:border-indigo-200 transition-colors no-underline">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              Email
            </a>
            <!-- Copy link -->
            <button data-share-copy
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-gray-200 text-sm text-gray-600 hover:bg-gray-100 hover:text-gray-700 transition-colors">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              <span data-share-label>Copy link</span>
            </button>
          </div>
        </div>

        <!-- Completion check (bottom of article) -->
        {slug && (
          <div class="mt-8 pt-6 border-t border-gray-200" data-pagefind-ignore>
            <div class="relative inline-flex">
              <button
                data-completion-btn
                data-section={sectionSlug}
                data-slug={slug}
                class="completion-btn-default inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium transition-all duration-200 border border-gray-300 text-gray-600 hover:border-indigo-400 hover:text-indigo-600"
              >
                <span data-completion-icon>
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>
                </span>
                <span data-completion-label>Mark as complete</span>
              </button>
              <a
                data-guest-overlay
                href="/register"
                class="absolute inset-0 flex items-center justify-center gap-1.5 rounded-lg bg-gray-100/80 text-gray-400 hover:bg-gray-200/90 transition-colors"
                aria-label="Create a free account to track progress"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              </a>
            </div>
            <p id="completion-guest-hint" class="mt-2 text-xs text-gray-400">
              <a href="/register" class="text-indigo-500 hover:text-indigo-700 font-medium">Create an account</a> to track your progress across all lessons.
            </p>

            {/* Up next — revealed client-side after marking complete */}
            {nextItem && (
              <div
                id="up-next-panel"
                class="hidden mt-5 flex items-center gap-4 rounded-xl bg-indigo-50 border border-indigo-100 px-5 py-4"
              >
                <div class="shrink-0 w-9 h-9 rounded-full bg-indigo-100 flex items-center justify-center">
                  <svg class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-xs font-semibold text-indigo-400 uppercase tracking-wide mb-0.5">Up next</p>
                  <a
                    href={nextItem.href}
                    class="font-semibold text-indigo-700 hover:text-indigo-900 no-underline hover:underline text-sm leading-snug block truncate"
                  >
                    {nextItem.title}
                  </a>
                  {nextItem.readingTime && (
                    <p class="text-xs text-indigo-400 mt-0.5">{nextItem.readingTime} min read</p>
                  )}
                </div>
                <a
                  href={nextItem.href}
                  class="shrink-0 px-4 py-2 bg-indigo-600 text-white text-xs font-semibold rounded-lg hover:bg-indigo-700 transition-colors no-underline"
                >
                  Continue →
                </a>
              </div>
            )}
          </div>
        )}
      </article>

      <!-- Sidebar -->
      <aside data-pagefind-ignore class="mt-10 lg:mt-0 space-y-8">
        {headings.length > 1 && (
          <TableOfContents headings={headings} locale={locale} />
        )}

        <!-- Completion check (sidebar) -->
        {slug && (
          <div class="rounded-xl border border-gray-200 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-3">Your progress</p>
            <div class="relative">
              <button
                data-completion-btn
                data-section={sectionSlug}
                data-slug={slug}
                class="completion-btn-default w-full inline-flex items-center justify-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 border border-gray-300 text-gray-600 hover:border-indigo-400 hover:text-indigo-600"
              >
                <span data-completion-icon>
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>
                </span>
                <span data-completion-label>Mark as complete</span>
              </button>
              <a
                data-guest-overlay
                href="/register"
                class="absolute inset-0 flex items-center justify-center gap-1.5 rounded-lg bg-gray-100/80 text-gray-400 hover:bg-gray-200/90 transition-colors"
                aria-label="Create a free account to track progress"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              </a>
            </div>
            <p id="sidebar-guest-hint" class="mt-2 text-xs text-gray-400 text-center">
              <a href="/register" class="text-indigo-500 hover:text-indigo-700 font-medium">Create an account</a> to track your progress.
            </p>

            {nextItem && (
              <div id="up-next-panel-sidebar" class="hidden mt-4 pt-4 border-t border-gray-100">
                <p class="text-xs font-semibold text-indigo-400 uppercase tracking-wide mb-2">Up next</p>
                <a
                  href={nextItem.href}
                  class="block font-semibold text-indigo-700 hover:text-indigo-900 no-underline hover:underline text-sm leading-snug mb-1"
                >
                  {nextItem.title}
                </a>
                {nextItem.readingTime && (
                  <p class="text-xs text-indigo-400 mb-3">{nextItem.readingTime} min read</p>
                )}
                <a
                  href={nextItem.href}
                  class="block w-full text-center px-4 py-2 bg-indigo-600 text-white text-xs font-semibold rounded-lg hover:bg-indigo-700 transition-colors no-underline"
                >
                  Continue →
                </a>
              </div>
            )}
          </div>
        )}

        <RelatedContent
          currentTags={tags}
          currentSection={sectionSlug}
          locale={locale}
        />
      </aside>
    </div>
  </div>
<!-- Share buttons script -->
<script>
  document.querySelectorAll('[data-share-container]').forEach(function(container) {
    const url = container.getAttribute('data-share-url') || '';
    const title = container.getAttribute('data-share-title') || '';

    const wa = container.querySelector('[data-share-whatsapp]');
    const tg = container.querySelector('[data-share-telegram]');
    const em = container.querySelector('[data-share-email]');
    const cp = container.querySelector('[data-share-copy]');

    const sig = '\n\n--\nStartup Super School - The Startup Encyclopedia\nhttps://www.startupsuperschool.com';
    const waText = 'Check out this article:\n\n' + title + '\n' + url + sig;
    if (wa) wa.setAttribute('href', 'https://wa.me/?text=' + encodeURIComponent(waText));

    const tgText = 'Check out this article:\n\n' + title + '\n' + url + sig;
    if (tg) tg.setAttribute('href', 'https://t.me/share/url?url=' + encodeURIComponent(url) + '&text=' + encodeURIComponent(tgText));

    const emailBody = 'Check out this article:\n\n' + title + '\n' + url + sig;
    if (em) em.setAttribute('href', 'mailto:?subject=' + encodeURIComponent(title) + '&body=' + encodeURIComponent(emailBody));

    if (cp) {
      const label = cp.querySelector('[data-share-label]');
      const original = label ? label.textContent : 'Copy link';
      cp.addEventListener('click', async function() {
        await navigator.clipboard.writeText(url);
        if (label) {
          label.textContent = 'Copied!';
          setTimeout(function() { label.textContent = original; }, 2000);
        }
      });
    }
  });
</script>

<!-- Completion check script -->
<script>
  const DONE_CLASS = ['border-green-500', 'text-green-600', 'bg-green-50'];
  const DEFAULT_CLASS = ['border-gray-300', 'text-gray-600'];
  const SVG_EMPTY = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>';
  const SVG_DONE = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12l3 3 5-5"/></svg>';

  function applyState(btn, done) {
    const icon = btn.querySelector('[data-completion-icon]');
    const label = btn.querySelector('[data-completion-label]');
    if (done) {
      btn.classList.remove('completion-btn-default', ...DEFAULT_CLASS);
      btn.classList.add(...DONE_CLASS);
      if (icon) icon.innerHTML = SVG_DONE;
      if (label) label.textContent = 'Completed';
    } else {
      btn.classList.remove(...DONE_CLASS);
      btn.classList.add('completion-btn-default', ...DEFAULT_CLASS);
      if (icon) icon.innerHTML = SVG_EMPTY;
      if (label) label.textContent = 'Mark as complete';
    }
  }

  function syncAll(done) {
    document.querySelectorAll('[data-completion-btn]').forEach(btn => applyState(btn, done));
  }

  function setUpNext(visible) {
    const action = visible ? 'remove' : 'add';
    document.getElementById('up-next-panel')?.classList[action]('hidden');
    document.getElementById('up-next-panel-sidebar')?.classList[action]('hidden');
  }

  // Set ?next= on all overlays
  const overlays = document.querySelectorAll('[data-guest-overlay]');
  overlays.forEach(function(overlay) {
    overlay.setAttribute('href', '/register?next=' + encodeURIComponent(window.location.pathname));
  });

  const hasSession = Object.keys(localStorage).some(k => k.includes('-auth-token'));

  if (hasSession) {
  const { supabase } = await import('../lib/supabase');
  const { data: { user } } = await supabase.auth.getUser();

  if (user) {
    // Logged in: remove overlays and guest hints
    overlays.forEach(function(overlay) { overlay.remove(); });
    const hint1 = document.getElementById('completion-guest-hint');
    const hint2 = document.getElementById('sidebar-guest-hint');
    if (hint1) hint1.classList.add('hidden');
    if (hint2) hint2.classList.add('hidden');

    // Load and render current completion state
    const btns = document.querySelectorAll('[data-completion-btn]');
    if (btns.length > 0) {
      const section = btns[0].dataset.section;
      const slug = btns[0].dataset.slug;

      const { data: existing } = await supabase
        .from('completions').select('id')
        .eq('user_id', user.id).eq('section', section).eq('slug', slug)
        .maybeSingle();

      let isDone = !!existing;
      syncAll(isDone);
      setUpNext(isDone);

      btns.forEach(function(btn) {
        btn.addEventListener('click', async function() {
          if (!isDone) {
            await supabase.from('completions').insert({ user_id: user.id, section, slug });
            isDone = true;
          } else {
            await supabase.from('completions').delete()
              .eq('user_id', user.id).eq('section', section).eq('slug', slug);
            isDone = false;
          }
          syncAll(isDone);
          setUpNext(isDone);
        });
      });
    }
  }
  } // end if (hasSession)
</script>
</BaseLayout>
